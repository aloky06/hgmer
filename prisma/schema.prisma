// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  ADMIN
  CUSTOMER
  PANDIT
  VENDOR
}

enum ProductType {
  STANDARD
  BUNDLE
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// --- MODELS ---

model User {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String?  @unique
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  pushToken    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  panditProfile PanditProfile?
  vendorProfile VendorProfile?
  bookings      Booking[]      @relation("CustomerBookings")
  orders        Order[]
  wishlists     Wishlist[]
  notifications Notification[]
}

model VendorProfile {
  id           Int       @id @default(autoincrement())
  userId       Int       @unique
  user         User      @relation(fields: [userId], references: [id])
  businessName String
  gstNumber    String?
  status       Status    @default(PENDING)
  products     Product[]
}

model PanditProfile {
  id            Int       @id @default(autoincrement())
  userId        Int       @unique
  user          User      @relation(fields: [userId], references: [id])
  bio           String?   @db.Text
  experience    Int       @default(0)
  city          String
  serviceRadius Int       @default(10) // in km
  videoIntroUrl String?
  status        Status    @default(PENDING)
  photoUrl        String?
  rating          Float     @default(4.8)
  price           Int       @default(6000)
  languages       String?   @db.Text
  specializations String?   @db.Text
  bookings      Booking[] @relation("PanditBookings")
}

model Category {
  id          Int       @id @default(autoincrement())
  parentId    Int?
  parent      Category? @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  name        String
  description String?   @db.Text
  iconUrl     String?
  isFestival  Boolean   @default(false)
  products    Product[]
}

model Banner {
  id        Int     @id @default(autoincrement())
  title     String
  subtitle  String?
  imageUrl  String
  actionUrl String?
  isActive  Boolean @default(true)
  isCampaign Boolean   @default(false)
  products   Product[] @relation("CampaignProducts")
}

model Festival {
  id       Int     @id @default(autoincrement())
  name     String
  date     String
  linkText String
  imageUrl String
  isActive Boolean @default(true)
}

model Product {
  id               Int               @id @default(autoincrement())
  vendorId         Int?
  vendor           VendorProfile?    @relation(fields: [vendorId], references: [id])
  categoryId       Int
  category         Category          @relation(fields: [categoryId], references: [id])
  name             String
  description      String            @db.Text
  price            Float
  mrp              Float?
  rating           Float             @default(0)
  reviewCount      Int               @default(0)
  stock            Int               @default(0) // Legacy stock, to be migrated to Inventory
  type             ProductType       @default(STANDARD)
  weight           Float? // value
  unit             String?           @default("kg") // kg, g, L, ml, pcs, pack
  length           Float? // in cm
  width            Float? // in cm
  height           Float? // in cm
  imageUrl         String?
  status           Status            @default(PENDING)
  adminNote        String?           @db.Text
  orderItems       OrderItem[]
  inventories      Inventory[]
  wishlistedBy     Wishlist[]
  images           ProductImage[]
  bundleComponents BundleComponent[] @relation("BundleToComponent")
  partOfBundles    BundleComponent[] @relation("ComponentToBundle")
  campaigns        Banner[]          @relation("CampaignProducts")
  poojaVidhiItems  PoojaVidhiItem[]
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String  @db.Text
  order     Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model BundleComponent {
  id          Int @id @default(autoincrement())
  bundleId    Int
  componentId Int
  quantity    Int

  bundle    Product @relation("BundleToComponent", fields: [bundleId], references: [id])
  component Product @relation("ComponentToBundle", fields: [componentId], references: [id])

  @@unique([bundleId, componentId])
}

model Warehouse {
  id                  Int         @id @default(autoincrement())
  name                String
  pincode             String?
  address             String?     @db.Text
  serviceablePincodes String?     @db.Text // JSON array of pincodes
  inventories         Inventory[]
  orderItems          OrderItem[]
}

model Inventory {
  id               Int                 @id @default(autoincrement())
  warehouseId      Int
  productId        Int
  quantity         Int                 @default(0)
  reservedQuantity Int                 @default(0)

  warehouse        Warehouse           @relation(fields: [warehouseId], references: [id])
  product          Product             @relation(fields: [productId], references: [id])
  auditLogs        InventoryAuditLog[]
  batches          InventoryBatch[]

  @@unique([warehouseId, productId])
}

model InventoryBatch {
  id          Int       @id @default(autoincrement())
  inventoryId Int
  batchNumber String
  quantity    Int       @default(0)
  expiryDate  DateTime?
  costPrice   Float?
  mrp         Float?
  createdAt   DateTime  @default(now())

  inventory   Inventory @relation(fields: [inventoryId], references: [id])
}

model PurchaseOrder {
  id          Int       @id @default(autoincrement())
  supplierId  Int?      // Nullable for ad-hoc inwards
  status      String    @default("PENDING") // PENDING, COMPLETED
  totalAmount Float     @default(0)
  createdAt   DateTime  @default(now())

  inwards     StockInward[]
}

model StockInward {
  id              Int       @id @default(autoincrement())
  purchaseOrderId Int
  warehouseId     Int
  productId       Int
  quantity        Int
  costPrice       Float
  batchNumber     String?
  expiryDate      DateTime?
  createdAt       DateTime  @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
}

model InventoryAuditLog {
  id               Int      @id @default(autoincrement())
  inventoryId      Int
  changeType       String // e.g., "ADD", "REMOVE", "ORDER_DEDUCT", "RESTOCK"
  quantityChanged  Int
  previousQuantity Int
  newQuantity      Int
  reason           String?  @db.Text
  createdAt        DateTime @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id])
}

model PoojaType {
  id          Int       @id @default(autoincrement())
  name        String
  description String?   @db.Text
  bookings    Booking[]
}

model Booking {
  id            Int           @id @default(autoincrement())
  customerId    Int
  customer      User          @relation("CustomerBookings", fields: [customerId], references: [id])
  panditId      Int
  pandit        PanditProfile @relation("PanditBookings", fields: [panditId], references: [id])
  poojaTypeId   Int
  poojaType     PoojaType     @relation(fields: [poojaTypeId], references: [id])
  date          DateTime
  time          String
  location      String
  status        BookingStatus @default(PENDING)
  paymentStatus String        @default("PENDING")
  hgmrCommission Float?
  panditAmount   Float?
  createdAt     DateTime      @default(now())
}

model Order {
  id              Int      @id @default(autoincrement())
  customerId      Int
  customer        User     @relation(fields: [customerId], references: [id])
  totalAmount     Float
  shippingAddress String   @db.Text
  status          String   @default("PENDING")
  paymentStatus   String   @default("PENDING")
  hgmrCommission  Float?
  vendorAmount    Float?
  cancelReason    String?  @db.Text
  createdAt       DateTime @default(now())

  // Shiprocket fields
  shiprocketOrderId    Int?
  shiprocketShipmentId Int?
  awbCode              String?
  courierCompanyId     Int?
  shippingLabelUrl     String? @db.Text

  orderItems OrderItem[]
}

model OrderItem {
  id          Int       @id @default(autoincrement())
  orderId     Int
  order       Order     @relation(fields: [orderId], references: [id])
  productId   Int
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId Int?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  quantity    Int
  price       Float
}

model PoojaVidhi {
  id          Int      @id @default(autoincrement())
  title       String
  procedure   String   @db.Text
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       PoojaVidhiItem[]
}

model PoojaVidhiItem {
  id           Int      @id @default(autoincrement())
  poojaVidhiId Int
  productId    Int
  quantity     Int      @default(1)

  poojaVidhi   PoojaVidhi @relation(fields: [poojaVidhiId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([poojaVidhiId, productId])
}

model ConsultancyService {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  price       Float
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Horoscope {
  id         Int      @id @default(autoincrement())
  sign       String
  prediction String   @db.Text
  date       DateTime @db.Date
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([sign, date])
}

model Panchang {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date @unique
  tithi       String?
  nakshatra   String?
  sunrise     String?
  sunset      String?
  details     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int
  title      String
  message    String   @db.Text
  type       String   @default("alert") // offer, order, alert
  linkType   String?  // 'product', 'category', 'none'
  linkTarget String?  // ID of the product or category
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
